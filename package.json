{
  "name": "astra-quant-lab-root",
  "version": "1.1.0",
  "private": true,
  "description": "Monorepo root configurations for Astra Quant Lab",
  "scripts": {
    "prepare": "husky install",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "prettier": "^3.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ]
  }
}
